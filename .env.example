# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Database
DATABASE_URL=sqlite:///./helpline.db

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# SMS Gateway (Mock for development)
SMS_PROVIDER=mock
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=HELPLINE

# Voice Service (Future)
VOICE_ENABLED=false